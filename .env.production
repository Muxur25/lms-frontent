# Production Environment — LMS AGMK Frontend
# Bu faylni .env.production deb saqlang va production URL'larni to'ldiring

# Backend API URL (production)
VITE_API_URL=https://api.lms.agmk.uz/api/v1

# WebSocket URL (production)
VITE_WS_URL=wss://api.lms.agmk.uz/ws

# Feature Flags
VITE_USE_MOCKS=false
VITE_ENABLE_AI_ASSISTANT=true
VITE_ENABLE_WEBINARS=true

# App Version
VITE_APP_VERSION=1.0.0
