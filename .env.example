# Enterprise Environment Variables Template

# Base API Configuration
VITE_API_BASE_URL=https://api.lms.agmk.uz/v1

# Feature Flags
VITE_USE_MOCKS=false
VITE_ENABLE_AI_ASSISTANT=true
VITE_ENABLE_WEBINARS=true

# Realtime WebSocket
VITE_WS_URL=wss://api.lms.agmk.uz/ws

# Analytics (Optional)
VITE_SENTRY_DSN=
VITE_GOOGLE_ANALYTICS_ID=

# PWA / Application config
VITE_APP_VERSION=1.0.0
