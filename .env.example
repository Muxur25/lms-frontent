# Enterprise Environment Variables Template

# Backend API URL. Must include the API version path used by the backend.
VITE_API_URL=https://api.lms.agmk.uz/api/v1

# Feature Flags
VITE_USE_MOCKS=false
VITE_ENABLE_AI_ASSISTANT=true
VITE_ENABLE_WEBINARS=true

# Realtime WebSocket. The app can derive this from VITE_API_URL, but keep it
# explicit for deployment platforms and future realtime clients.
VITE_WS_URL=wss://api.lms.agmk.uz/realtime

# Analytics (optional)
VITE_SENTRY_DSN=
VITE_GOOGLE_ANALYTICS_ID=

# PWA / application config
VITE_APP_VERSION=1.0.0
